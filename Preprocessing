// Group Project-Scam Centre in SEA countries

// 0 Centering the map on a SEA country Cambodia
Map.setCenter(103.524, 10.627, 7);

function maskS2(image) {
  var qa = image.select('QA60');

  var cloudBitMask = 1 << 10;
  var cirrusBitMask = 1 << 11;

  var mask = qa.bitwiseAnd(cloudBitMask).eq(0)
      .and(qa.bitwiseAnd(cirrusBitMask).eq(0));

  return image.updateMask(mask);
}
 
// 1 Define AOI(Area of Interest)
var aoi = ee.Geometry.Point(103.524, 10.627).buffer(5000); // Sihanoukville
Map.centerObject(aoi, 12);

// 2 Sentinel2 and looingfor build-up area and enclosure
var s2 = ee.ImageCollection("COPERNICUS/S2_SR")
  .filterBounds(aoi)
  .filterDate('2018-01-01', '2023-12-31')
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))
  .map(maskS2)
  .select(['B2','B3','B4','B8','B11'])
  .median();

Map.addLayer(s2, {bands: ['B4', 'B3', 'B2'], min: 0, max: 3000}, 'Sentinel-2 RGB');

// 3 Night-Time Lights (key insight)
var ntl = ee.ImageCollection("NOAA/VIIRS/DNB/MONTHLY_V1/VCMCFG")
  .filterBounds(aoi)
  .filterDate('2018-01-01', '2023-12-31')
  .mean();

Map.addLayer(ntl, {min: 0, max: 50}, 'Night Lights');

// 4 Change Detection
var before = ee.ImageCollection("COPERNICUS/S2_SR")
  .filterBounds(aoi)
  .filterDate('2018-01-01', '2019-12-31')
  .map(maskS2)
  .select(['B2','B3','B4','B8','B11'])
  .median();

var after = ee.ImageCollection("COPERNICUS/S2_SR")
  .filterBounds(aoi)
  .filterDate('2022-01-01', '2023-12-31')
  .map(maskS2)
  .select(['B2','B3','B4','B8','B11'])
  .median();

Map.addLayer(before, {bands: ['B4','B3','B2'], min:0, max:3000}, 'Before');
Map.addLayer(after, {bands: ['B4','B3','B2'], min:0, max:3000}, 'After');

// 5 Built-up Index (NDBI)
var ndbi = after.normalizedDifference(['B11', 'B8']).rename('NDBI');
Map.addLayer(ndbi, {min: -1, max: 1, palette: ['blue', 'white', 'red']}, 'NDBI');

