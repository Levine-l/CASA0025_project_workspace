// 2. 增强预处理：添加 NDVI 和 纹理特征
function addIndices(image) {
  var ndbi = image.normalizedDifference(['B11', 'B8']).rename('NDBI'); // 
  var ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI');  // [cite: 85-89]
  // 计算纹理特征 (GLCM) 以识别规律的建筑排列 [cite: 80]
  var glcm = image.select('B8').toUint16().glcmTexture({size: 4}); 
  return image.addBands([ndbi, ndvi, glcm]);
}

// 3. 应用处理
var composite = ee.ImageCollection("COPERNICUS/S2_SR")
  .filterBounds(aoi)
  .filterDate('2023-01-01', '2023-12-31')
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))
  .map(maskS2)
  .map(addIndices)
  .median()
  .clip(aoi);

